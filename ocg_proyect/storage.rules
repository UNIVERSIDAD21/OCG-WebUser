rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminByClaim() {
      return isSignedIn() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.admin == true
      );
    }

    function isAdminByDoc() {
      return isSignedIn() &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    function isAdmin() {
      return isAdminByClaim() || isAdminByDoc();
    }

    function isOwnPatient(patientId) {
      return isSignedIn() && request.auth.uid == patientId;
    }

    function simulationDoc(patientId, simulationId) {
      return firestore.get(
        /databases/(default)/documents/patients/$(patientId)/simulations/$(simulationId)
      );
    }

    function canReadSharedSimulation(patientId, simulationId) {
      return isOwnPatient(patientId)
        && simulationDoc(patientId, simulationId).data.compartidaConPaciente == true
        && simulationDoc(patientId, simulationId).data.status == 'shared';
    }

    match /patients/{patientId}/profile/{fileName} {
      allow read: if isAdmin() || isOwnPatient(patientId);
      allow write: if isAdmin();
    }

    match /patients/{patientId}/photos/{fileName} {
      allow read: if isAdmin() || isOwnPatient(patientId);
      allow write: if isAdmin();
    }

    match /patients/{patientId}/clinical-files/{fileName} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /patients/{patientId}/treatments/{treatmentId}/clinical-files/{fileName} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /simulations/{patientId}/{simulationId}/{fileName} {
      allow read: if isAdmin() || canReadSharedSimulation(patientId, simulationId);
      allow write: if isAdmin();
    }

    match /simulator_temp/{sessionId}/{fileName} {
      allow read, write: if isAdmin();
    }
  }
}
