rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.role == 'admin' ||
        request.auth.token.admin == true ||
        (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    function isOwnPatient(patientId) {
      return request.auth != null && request.auth.uid == patientId;
    }

    function incomingPatientMatches(patientId) {
      return !('patientId' in request.resource.data) || request.resource.data.patientId == patientId;
    }

    function incomingTreatmentMatches(treatmentId) {
      return !('treatmentId' in request.resource.data) || request.resource.data.treatmentId == treatmentId;
    }

    function hasAuditFields() {
      return ('createdAt' in request.resource.data) &&
             ('updatedAt' in request.resource.data) &&
             ('createdBy' in request.resource.data) &&
             ('updatedBy' in request.resource.data);
    }

    match /admins/{adminId} {
      allow read: if isAdmin() || isOwnPatient(adminId);
      allow write: if isAdmin();

      match /devices/{deviceId} {
        allow read: if isAdmin() || isOwnPatient(adminId);
        allow create, update: if isAdmin() || isOwnPatient(adminId);
        allow delete: if false;
      }
    }

    match /patients/{patientId} {
      allow read: if isAdmin() || isOwnPatient(patientId);
      allow create: if isAdmin() ||
                      (request.auth != null && isOwnPatient(patientId));
      allow update: if isAdmin() ||
                      (request.auth != null && isOwnPatient(patientId));
      allow delete: if isAdmin();

      match /devices/{deviceId} {
        allow read: if isAdmin() || isOwnPatient(patientId);
        allow create, update: if isAdmin() || isOwnPatient(patientId);
        allow delete: if false;
      }

      match /photos/{photoId} {
        allow read: if isAdmin() || isOwnPatient(patientId);
        allow create, update: if isAdmin();
        allow delete: if isAdmin();
      }

      match /stageHistory/{entryId} {
        allow read: if isAdmin() || isOwnPatient(patientId);
        allow create: if isAdmin() &&
                        incomingPatientMatches(patientId) &&
                        (!('id' in request.resource.data) || request.resource.data.id == entryId);
        allow update, delete: if false;
      }

      match /treatments/{treatmentId} {
        allow read: if isAdmin() || isOwnPatient(patientId);
        allow create, update: if isAdmin() &&
                                incomingPatientMatches(patientId) &&
                                (!('id' in request.resource.data) || request.resource.data.id == treatmentId);
        allow delete: if false;

        match /stageHistory/{entryId} {
          allow read: if isAdmin() || isOwnPatient(patientId);
          allow create: if isAdmin() &&
                          incomingPatientMatches(patientId) &&
                          incomingTreatmentMatches(treatmentId) &&
                          (!('id' in request.resource.data) || request.resource.data.id == entryId);
          allow update, delete: if false;
        }

        match /financialItems/{itemId} {
          allow read: if isAdmin() || isOwnPatient(patientId);
          allow create, update: if isAdmin() &&
                                  incomingPatientMatches(patientId) &&
                                  incomingTreatmentMatches(treatmentId) &&
                                  (!('id' in request.resource.data) || request.resource.data.id == itemId) &&
                                  hasAuditFields();
          allow delete: if isAdmin();
        }
      }

      match /clinicalFiles/{fileId} {
        allow read: if isAdmin() ||
                    (isOwnPatient(patientId) &&
                     resource.data.visibleToPatient == true &&
                     resource.data.active == true);
        allow create, update: if isAdmin() &&
                                incomingPatientMatches(patientId) &&
                                (!('id' in request.resource.data) || request.resource.data.id == fileId);
        allow delete: if false;
      }

      match /simulations/{simulationId} {
        allow read: if isAdmin() ||
                      (
                        isOwnPatient(patientId) &&
                        resource.data.compartidaConPaciente == true &&
                        resource.data.status == 'shared'
                      );
        allow create, update, delete: if isAdmin();
      }
    }

    match /appointments/{appointmentId} {
      allow read: if isAdmin() ||
                    (request.auth != null &&
                     resource.data.patientId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin() ||
                      (request.auth != null &&
                       resource.data.patientId == request.auth.uid &&
                       request.resource.data.estado == 'cancelada');
      allow delete: if isAdmin();
    }

    match /payments/{patientId} {
      allow read: if isAdmin() || isOwnPatient(patientId);
      allow create, update, delete: if isAdmin();

      match /transactions/{txId} {
        allow read: if isAdmin() || isOwnPatient(patientId);
        allow create, update, delete: if isAdmin();
      }

      match /treatments/{treatmentId} {
        allow read: if isAdmin() || isOwnPatient(patientId);
        allow create, update, delete: if isAdmin() &&
                                        incomingPatientMatches(patientId) &&
                                        incomingTreatmentMatches(treatmentId);

        match /transactions/{txId} {
          allow read: if isAdmin() || isOwnPatient(patientId);
          allow create, update, delete: if isAdmin() &&
                                          incomingPatientMatches(patientId) &&
                                          incomingTreatmentMatches(treatmentId) &&
                                          (!('id' in request.resource.data) || request.resource.data.id == txId);
        }
      }
    }

    match /payu_sessions/{sessionId} {
      allow read, write: if false;
    }

    match /simulations/{simId} {
      allow read: if isAdmin() ||
                    (request.auth != null &&
                     resource.data.patientId == request.auth.uid);
      allow create: if request.auth != null &&
                      (isAdmin() ||
                       request.resource.data.patientId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if request.auth != null &&
                    resource.data.recipientId == request.auth.uid;
      allow create: if isAdmin();
      allow update: if request.auth != null &&
                      resource.data.recipientId == request.auth.uid;
      allow delete: if false;
    }

    match /scheduledNotifications/{notificationId} {
      allow read: if isAdmin() ||
                    (request.auth != null && resource.data.patientId == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /availability/{dayKey} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /treatmentCatalog/{catalogTreatmentId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin();
      allow delete: if false;
    }
  }
}
